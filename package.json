{
  "name": "code-agent-lite",
  "version": "0.1.0",
  "private": true,
  "description": "A minimal ReAct code agent for learning agent internals.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx packages/cli/src/main.tsx",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "start": "node packages/cli/dist/main.js",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.18",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
