# 复制本文件为 .env，填入真实密钥（.env 已被 git 忽略，不会提交）

# ========== OpenAI（默认模式，必填）==========
# 在 https://platform.openai.com/api-keys 创建，形如 sk-proj-...
OPENAI_API_KEY=

# 国内/自建网关时改成你的 base URL；官方 OpenAI 可省略
# OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名，可省略（由平台默认）
# OPENAI_MODEL=gpt-4o

# 思考链展示，false 关闭
# ENABLE_THINKING=true

# ========== Cursor Provider（可选）==========
# 主 Agent 走 Cursor SDK 时设置 AGENT_PROVIDER=cursor
# 密钥在 https://cursor.com/settings（或 Cursor 账户 API 页）获取
# AGENT_PROVIDER=cursor
# CURSOR_API_KEY=
# CURSOR_MODEL=composer-2.5
# CURSOR_MODEL_FAST=true

# 注意：即使用 cursor 模式，路由/规划/验证仍需要 OPENAI_API_KEY（或兼容 OpenAI 的网关）
