{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Core Turn Test",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "__test__/debug/turn-flow.test.ts", "--testTimeout=0"],
      "cwd": "${workspaceFolder}/packages/core",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug CLI (Ink)",
      "program": "${workspaceFolder}/packages/cli/src/main.tsx",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "runtimeArgs": ["--import", "tsx"],
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
